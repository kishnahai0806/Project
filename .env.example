SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/campus_event_hub
SPRING_DATASOURCE_USERNAME=campus_user
SPRING_DATASOURCE_PASSWORD=campus_password
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=replace-with-very-long-base64ish-secret-at-least-32-chars
JWT_EXPIRATION_MS=3600000
CACHE_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379
APP_SEED_ENABLED=true
